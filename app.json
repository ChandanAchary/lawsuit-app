{
  "expo": {
    "name": "Lawsuit",
    "slug": "lawsuit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lawsuit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B4D64"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.msdchandan.lawsuitapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B4D64",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.msdchandan.lawsuitapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0B4D64",
          "androidMode": "default"
        }
      ]
    ],
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0,
      "url": ""
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "df59adf1-1f7e-4175-8c41-34ed1d6e48a2"
      }
    },
    "owner": "msdchandan"
  }
}

{
  "expo": {
    "name": "NyayaX",
    "slug": "NyayaX",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "nyayax",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F4F6"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.chandan.NyayaX",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NyayaX needs your location to find lawyers near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NyayaX needs your location to find lawyers near you.",
        "NSCameraUsageDescription": "NyayaX needs camera access to upload your profile photo and documents.",
        "NSMicrophoneUsageDescription": "NyayaX needs microphone access for audio and video consultations.",
        "NSPhotoLibraryUsageDescription": "NyayaX needs photo library access to upload documents and profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B4D64",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.msdchandan.lawsuitapp",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#0F0F1A",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0B4D64",
          "androidMode": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "NyayaX needs your location to show lawyers near you.",
          "locationWhenInUsePermission": "NyayaX needs your location to show lawyers near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NyayaX needs access to your photos to upload profile pictures and documents.",
          "cameraPermission": "NyayaX needs camera access to take profile pictures and document photos.",
          "microphonePermission": "NyayaX needs microphone access for video consultations."
        }
      ],
      "expo-audio"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/73a2f4bc-1a1a-40b6-a09a-65f0b94038b9"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "expo-chandan",
    "extra": {
      "eas": {
        "projectId": "73a2f4bc-1a1a-40b6-a09a-65f0b94038b9"
      }
    }
  }
}

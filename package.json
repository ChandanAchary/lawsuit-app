{
  "name": "NyayaX",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --go --lan",
    "start:tunnel": "expo start --go --tunnel",
    "start:dev-client": "expo start --dev-client",
    "android": "expo start --go --android",
    "ios": "expo start --go --ios",
    "web": "expo start --web",
    "eas:build:android:staging": "eas build --platform android --profile preview",
    "eas:build:ios:staging": "eas build --platform ios --profile preview",
    "eas:build:android:production": "eas build --platform android --profile production",
    "eas:build:ios:production": "eas build --platform ios --profile production",
    "eas:update:staging": "eas update --channel staging --environment staging --message \"staging update\"",
    "eas:update:production": "eas update --channel production --environment production --message \"production update\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
